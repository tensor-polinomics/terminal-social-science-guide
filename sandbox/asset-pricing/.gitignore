# --- Data: never commit raw or derived data ---
# Raw data here is simulated, but we treat it exactly as we
# would treat licensed CRSP/Compustat or restricted microdata:
# it is rebuilt from code, not stored in Git. The synthetic
# data IS the teachable moment (see PLAN.md Section 7).
data/raw/
data/clean/

# --- Generated outputs (regenerated by make; not committed) ---
# The whole output/ tree (the figure AND the R table) is rebuilt
# from the scripts by `make`, so none of it is tracked. This
# matches the repo-root policy (/sandbox/**/output/).
output/
*.parquet

# --- Quarto render products (verified, not committed) ---
report.html
report.pdf
report.tex
report.knit.md
report_files/

# --- Secrets: never commit credentials ---
.env
*.pem
secrets.*

# --- Python noise ---
__pycache__/
*.pyc
.ipynb_checkpoints/
.venv/

# --- R noise ---
.Rhistory
.Rproj.user/
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/staging/

# --- OS / editor noise ---
.DS_Store
